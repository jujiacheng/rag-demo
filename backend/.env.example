# ===== 智谱 GLM（OpenAI 兼容接口）=====
# 填入你自己的智谱 API Key，获取地址：https://open.bigmodel.com/
ZHIPUAI_API_KEY=your_zhipuai_api_key_here

# LLM 与 Embedding 配置（OpenAI 兼容 base_url，默认指向智谱）
LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
LLM_MODEL=glm-5.2
EMBEDDING_MODEL=embedding-3

# ===== Milvus 配置 =====
# 注意：不要在这里设置 MILVUS_URI 为本地 .db 路径——pymilvus 会在 import 时
# 读取 .env 并把 MILVUS_URI 当作网络 URI 解析，相对路径会直接抛错。
# 本地 milvus-lite 的默认值（./milvus_demo.db）已在 app/config.py 中给出。
# 切到完整服务器时取消注释并填写：
# MILVUS_URI=http://localhost:19530
COLLECTION_NAME=rag_demo

# ===== 知识库切分参数 =====
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# ===== 检索参数 =====
K=4
