# ===== 智谱 GLM（OpenAI 兼容接口）=====
# 填入你自己的智谱 API Key，获取地址：https://open.bigmodel.com/
ZHIPUAI_API_KEY=your_zhipuai_api_key_here

# LLM 与 Embedding 配置（OpenAI 兼容 base_url，默认指向智谱）
LLM_BASE_URL=https://open.bigmodel.com/api/paas/v4/
LLM_MODEL=glm-4.6
EMBEDDING_MODEL=embedding-3

# ===== Milvus 配置 =====
# 默认使用 milvus-lite（单文件，零运维）；切到完整服务器时改成 http://localhost:19530
MILVUS_URI=./milvus_demo.db
COLLECTION_NAME=rag_demo

# ===== 知识库切分参数 =====
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# ===== 检索参数 =====
K=4
